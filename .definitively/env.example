# Log level: TRACE | DEBUG | INFO (default) | WARN | ERROR
# DEFINITIVELY_LOG_LEVEL=INFO

# Optional: override workspace root discovered from the program path.
# DEFINITIVELY_WORKSPACE=/path/to/repo

# Default agent profile for LLM nodes (per-node `agent:` overrides this).
# Profiles live in .definitively/agents/<id>.yml
# DEFINITIVELY_AGENT=cursor

# Override executable for the cursor profile (NixOS/home-manager):
# DEFINITIVELY_AGENT_CURSOR_EXECUTABLE=/run/current-system/sw/bin/cursor-agent

# GitHub CLI auth for gh nodes (alternative to `gh auth login`)
# GH_TOKEN=
