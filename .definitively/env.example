# Log level: TRACE | DEBUG | INFO (default) | WARN | ERROR
# DEFINITIVELY_LOG_LEVEL=INFO

# Optional: override workspace root discovered from the program path.
# ORCHESTRATOR_WORKSPACE=/path/to/repo

# LLM nodes invoke cursor-agent; override for NixOS/home-manager:
# DEFINITIVELY_CURSOR_AGENT=/run/current-system/sw/bin/cursor-agent

# GitHub CLI auth for gh nodes (alternative to `gh auth login`)
# GH_TOKEN=
