digraph G {

  v0 [label="format\n(active)\n→ moon_format",shape="box",style="filled",fillcolor="lightyellow",fontname="Helvetica"]
  v1 [label="idle\n(passive)",shape="ellipse",style="filled",fillcolor="lightblue",fontname="Helvetica",penwidth="3",color="darkgreen"]
  v2 [label="done\n(final)",shape="doublecircle",style="filled",fillcolor="lightgray",fontname="Helvetica"]
  v3 [label="lint\n(active)\n→ moon_lint",shape="box",style="filled",fillcolor="lightyellow",fontname="Helvetica"]
  v4 [label="doctor\n(active)\n→ moon_doctor",shape="box",style="filled",fillcolor="lightyellow",fontname="Helvetica"]
  v5 [label="failed\n(final)",shape="doublecircle",style="filled",fillcolor="lightgray",fontname="Helvetica"]

  v0 -> v3 [label="success"]
  v0 -> v5 [label="failure"]
  v1 -> v0 [label="start"]
  v3 -> v4 [label="success"]
  v3 -> v5 [label="failure"]
  v4 -> v2 [label="success"]
  v4 -> v5 [label="failure"]

}