{
	"python.defaultInterpreterPath": "${workspaceFolder}/.devenv/state/venv/bin/python",
	"jupyter.notebookFileRoot": "${workspaceFolder}",
	"rust-analyzer.cargo.targetDir": "target/rust-analyzer",
	"rust-analyzer.linkedProjects": ["Cargo.toml"],
	"rust-analyzer.files.excludeDirs": ["target", "node_modules", ".git"],
	"rust-analyzer.workspace.symbol.search.scope": "workspace",
	"terminal.integrated.env.linux": {
		"TMPDIR": "${workspaceFolder}/tmp"
	},
	"terminal.integrated.env.osx": {
		"TMPDIR": "${workspaceFolder}/tmp"
	},
	"terminal.integrated.env.windows": {
		"TMPDIR": "${workspaceFolder}\\tmp"
	}
}
